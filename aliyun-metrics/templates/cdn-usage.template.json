{
  "scope": {
    "resource_type": "CDN resource package usage",
    "scope_type": "global_account_usage",
    "selection_basis": "当前已登录目标云平台会话（默认阿里云）下，综合 CDN 概览页的月累计用量/带宽摘要与资源包管理页的有效资源包总量/剩余量"
  },
  "collection": {
    "source": "Cloud Provider CDN console",
    "dashboard_view": "CDN 概览 + 资源包管理",
    "apis_observed": ["DescribeUserDomains"],
    "secondary_signals": [
      "近7天带宽峰值",
      "概览页资源包计费看板",
      "资源包管理页有效资源包列表"
    ]
  },
  "time_window": {
    "start": "YYYY-MM-DD HH:MM:SS",
    "end": "YYYY-MM-DD HH:MM:SS",
    "timezone": "Asia/Shanghai",
    "snapshot_date": "YYYY-MM-DD",
    "source": "invocation.time_window"
  },
  "intended_use": [
    "weekly_report_capacity_context",
    "cdn_cost_and_package_review"
  ],
  "generated_at": "YYYY-MM-DDTHH:MM:SS+08:00",
  "metric_scope": "all",
  "metric_coverage": {
