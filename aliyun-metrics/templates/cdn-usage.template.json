  "report_compatibility": {
    "weekly_alignment": "not_exact",
    "reason": "CDN 概览页展示的是当月累计用量，资源包管理页展示的是总量递减型资源包当前剩余量；两者共同作为统计背景信息，不代表严格按周扣减。"
  },
  "report_highlights": [
    "当前账号下共有 X 个 CDN 域名，概览页显示 X 个均处于正常运行。",
